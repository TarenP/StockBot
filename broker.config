# Broker configuration
# Edit these values — they become your defaults every run.
# Any flag you pass on the command line will override these.

cash           = 10000    # starting cash (first run only — ignored after that)
max_positions  = 10       # focused portfolio — 10 names on $10k is enough
stop_loss      = 0.180   # ATR-adjusted upward per stock; 8% floor avoids noise clips
take_profit    = 0.292   # full exit — realistic for a daily-checked system
partial_profit = 0.114   # take half off at +15%, let rest run to take_profit
min_score      = 0.656   # high enough to filter mediocre setups
penny_pct      = 0.03     # minimal speculative exposure until system is proven
max_sector     = 0.190   # prevents correlated sector drawdowns
max_correlation = 0.80    # blocks adding names that are too correlated with held positions
avoid_earnings = 2       # earnings risk starts well before the report date
top_n          = 500      # sufficient universe for a $10k daily broker
max_daily_loss = 0.025    # tighter during paper trading — 2.5% daily halt
max_drawdown   = 0.12     # tighter during paper trading — 12% circuit breaker
no_options     = true     # disabled until stock-side edge is proven in paper trading

# RL integration settings
rl_enabled            = true   # set true to activate RL ranking
rl_checkpoint_path    = models/best_fold1.pt                               # auto = use best available checkpoint in models/
rl_phase              = 1                  # 1=ranking, 2=ranking+exits, 3=weights (future)
rl_exit_threshold     = 0.470              # Phase 2: sell if rank_pct drops below this (bottom 20% of shortlist)
rl_conviction_drop    = 0.227              # Phase 2: sell 50% if rank_pct drops by this much from entry
rl_min_score          = 0.0               # Phase 1: min rl_score to enter (0 = top-k only)
