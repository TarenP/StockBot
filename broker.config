# Broker configuration
# Edit these values - they become your defaults every run.
# Any flag you pass on the command line will override these.

universe_mode  = tradable_us # broad U.S. tradable-equity universe; SPY is benchmark only
live_target_size = 1500      # breadth to maintain in the price/news universe
prune_universe_rows = false  # keep broad history; do not clip parquet to benchmark membership
allow_etfs     = false       # benchmark is SPY, but ETFs are not tradable names by default
allow_otc      = false
allow_preferreds = false
allow_warrants = false
allow_structured_instruments = false
universe_min_price = 2.0
universe_min_avg_volume = 500000
universe_min_history_days = 252
universe_max_stale_days = 30
prune_stale_history = false  # keep delisted/stale names in parquet for honest historical tests
benchmark_symbols = SPY      # benchmark data should stay in the parquet even though ETFs are not tradable
freeze_universe_snapshot = false
universe_snapshot_path = plots/live_universe_snapshot.json
include_watchlist_in_universe = false
min_broad_universe_size = 900
min_fresh_price_coverage = 0.90
min_fresh_sentiment_coverage = 0.50

cash           = 10000       # starting cash (first run only - ignored after that)
max_positions  = 20          # more positions = more capital deployed
stop_loss      = 0.10       # ATR-adjusted upward per stock; 8% floor avoids noise clips
take_profit    = 0.60       # disable the hard winner cap; trailing exits manage the rest
partial_profit = 0.350       # trim later so real leaders can compound
trailing_stop  = 0.120       # exit a winner only after it gives back a meaningful chunk from the peak
trailing_activation = 0.140  # lowered from 0.180 — engage trailing sooner so winners don't round-trip
signal_exit_score = 0.180    # only very weak composite scores are eligible for heuristic exits
signal_exit_grace = 2        # require repeated weakness before bailing
min_score      = 0.58        # slightly lower to keep capital deployed in strong tapes
penny_pct      = 0.03        # minimal speculative exposure until system is proven
max_sector     = 0.30       # still diversified, but less likely to choke sector leaders
max_correlation = 0.80       # blocks adding names that are too correlated with held positions
theme_max_pct  = 0.350       # cap economic theme clusters that sector labels miss
low_price_max_pct = 0.250    # aggregate cap for sub-$10 names
sentiment_policy = informational # logged as a feature; not a buy veto by itself
sentiment_negative_weight_mult = 0.800 # used when sentiment_policy=penalize_negative
sentiment_veto_composite_floor = 0.500 # used when sentiment_policy=veto_negative
weak_theme_min_positions = 2    # apply weak-sleeve penalty when this many open names in a theme are losing
weak_theme_return_threshold = -0.030 # avg open theme return at/below this triggers weak-sleeve penalty
weak_theme_penalty_mult = 0.500 # multiplier for new entries into weak correlated sleeves
weak_theme_cooldown_cycles = 0 # optional no-new-entry cooldown cycles after repeated weak-sleeve hits
weak_theme_cooldown_min_hits = 2 # consecutive weak-sleeve detections before cooldown starts
low_price_rank_policy = late_cap # late_cap, pre_penalty, or exclude_high_rank
low_price_rank_penalty_mult = 0.700 # ranking multiplier for sub-$10 names when policy=pre_penalty
low_price_high_rank_floor = 0.800 # rank floor used by exclude_high_rank low-price policy
earnings_reaction_enabled = true # soft rank/size adjustment when post-earnings reaction data exists
earnings_reaction_rank_strength = 0.100 # max rank nudge from earnings reaction score in [-1, 1]
earnings_reaction_weight_strength = 0.100 # max size nudge from earnings reaction score in [-1, 1]
macro_regime_enabled = true # soft size adjustment from current market regime/risk score
macro_regime_weight_strength = 0.080 # max macro regime size nudge
insider_adjustment_enabled = true # soft rank/size adjustment when insider activity data exists
insider_adjustment_rank_strength = 0.080 # max rank nudge from insider signal score in [-1, 1]
insider_adjustment_weight_strength = 0.080 # max size nudge from insider signal score in [-1, 1]
llm_sidecar_enabled = true # read cached local-LLM event features; never call LLM in broker hot path
llm_sidecar_broker_influence = false # diagnostics/memos only until replay validation promotes influence
llm_sidecar_min_confidence = 0.650 # cached parses below this are diagnostics-only unknowns
llm_cache_dir = broker/state/llm_cache
llm_document_store_dir = broker/state/document_store
llm_max_document_chars = 24000
enable_llm_sidecar_precompute = true # precompute cached parses; broker influence remains disabled below
llm_quality_min_coverage = 0.500 # minimum parsed/raw document coverage before influence experiments
llm_quality_max_invalid_rate = 0.100 # maximum invalid parse-file rate before influence experiments
llm_quality_max_review_backlog = 50 # manual-review queue must stay manageable
llm_quality_min_trusted_parses = 20 # collect enough trusted parses before any influence experiment
llm_quality_max_staleness_days = 14 # parses older than this are counted as stale
avoid_earnings = 4           # shorter buffer keeps more candidates investable
top_n          = 500         # tradable subset used for training / scoring from the broad universe
autotune_search_mode = fast  # fast = budgeted weekly parameter correction; full = exhaustive grid
autotune_max_combinations = 96 # max weekly parameter replay combos in fast mode
autotune_holdout_finalists = 6 # finalist replays after the search slice
shadow_validation_top_n = 6 # weekly shadow genomes to full-replay after fast scoring
shadow_replay_years = 1    # trailing years used for weekly shadow validation
max_daily_loss = 0.050       # relaxed from 0.025 — avoid blocking trades after one bad day
max_drawdown   = 0.200      # relaxed from 0.12 — normal equity drawdowns hit 12% too easily
max_position_pct = 0.18     # bigger single-name sizing so replay can actually express conviction
cash_floor     = 0.03       # raised from 0.010 — keep dry powder for opportunities
max_gross_exposure = 0.99   # stay close to fully invested when signals are strong
dead_money_days = 15         # exit positions with no progress after this many trading days
dead_money_min_return = 0.02 # "no progress" = return below this threshold
target_volatility = 0.15    # reduce needless de-risking during healthy bull regimes
vol_lookback   = 20          # realized-vol lookback for the risk scaler
no_options     = true        # disabled until stock-side edge is proven in paper trading

# RL integration settings
rl_enabled            = false
rl_checkpoint_path    = auto   # auto = use best available checkpoint in models/
rl_phase              = 2      # enable Phase 2 conviction-drop exits — the biggest quick win
rl_exit_threshold     = 0.150  # only used in Phase 2
rl_conviction_drop    = 0.250  # only used in Phase 2
rl_min_score          = 0.0    # Phase 1: min rl_rank_pct to enter (0 = top-k only)
